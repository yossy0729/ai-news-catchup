# --- 機密情報（絶対にコミットしない） ---
.env
.env.*
*.key
secrets.*

# --- 依存パッケージ（再インストール可能なので含めない） ---
node_modules/

# --- 自動生成・実行ログ（成果物ではない） ---
logs/
*.log
server-runtime.log

# --- 画面確認用スクリーンショット（任意・履歴を汚さない） ---
preview*.png

# --- 日次更新で再生成されるデータ ---
# 表示用データ(news/media/official/ai-signals)は静的公開(GitHub Pages)のためGit管理する。
# サーバ側の作業ファイル(候補/レビュー)のみ除外する。
data/candidates.json
data/review.json

# --- 外部APIキャッシュ（再取得可能。sota.jsonは履歴保存のため管理対象に残す） ---
data/cache/

# --- ツール／ブラウザの一時データ ---
.chrome-profile-shot/
.agents/

# --- OS / エディタ ---
.DS_Store
Thumbs.db
.vscode/
.idea/
